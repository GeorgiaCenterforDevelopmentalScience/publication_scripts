  W_TMEAN5 WITH FPDSP25 (sigma_TP);
  W_TMEAN7 WITH FPDSP27 (sigma_TP);

tsa1_min WITH tsa3_min tsa5_min tsa7_min (sm);
tsa3_min WITH tsa5_min tsa7_min (sm) ;
tsa5_min WITH tsa7_min (sm) ;
