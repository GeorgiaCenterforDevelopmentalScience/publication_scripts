samptime3 WITH samptime5 samptime7 (st) ;
samptime5 WITH samptime7 (st) ;

tsa1_min WITH samptime (ss);
tsa3_min WITH samptime3 (ss);
tsa5_min WITH samptime5 (ss);
tsa7_min WITH samptime7 (ss);

R_EMEAN1 WITH R_EMEAN3 R_EMEAN5 R_EMEAN7 ;
R_EMEAN3 WITH R_EMEAN5 R_EMEAN7 ;
R_EMEAN5 WITH R_EMEAN7 ;




INTYR3 ON R_EMEAN3  ;
